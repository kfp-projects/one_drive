# =============================================================================
# image_cleaner.py — configuração
# Copie este arquivo para .env e preencha os valores.
# =============================================================================

# Chave de API do Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Pasta raiz a varrer (use o caminho local sincronizado do OneDrive/Drive)
ROOT_FOLDER_PATH=C:\Users\kfpno\OneDrive - Kfp Distribuidora Ltda

# Onde mover arquivos irrelevantes (a estrutura de subpastas é preservada)
QUARANTINE_FOLDER=./_QUARENTENA_IMAGENS

# Extensões consideradas imagem (separadas por vírgula, com ponto)
IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.gif,.bmp,.webp,.tiff,.heic

# Tamanho máximo do lado do thumbnail enviado ao Gemini (pixels)
THUMBNAIL_SIZE=512

# Confiança mínima para mover automaticamente no modo --auto (0-100)
AUTO_MOVE_THRESHOLD=90

# Modo padrão quando nenhum flag é passado: dry_run | review | auto
RUN_MODE=dry_run

# Tamanho mínimo do arquivo para vale a pena analisar (bytes).
# Abaixo disso pula (provavelmente ícone/thumbnail/sprite). 0 desativa.
MIN_FILE_SIZE_BYTES=8192
